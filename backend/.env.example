PORT=5000
NODE_ENV=development

# Frontend base URL used to build password reset links
FRONTEND_URL=http://localhost:5173

# Database
DB_DIALECT=sqlite
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=neondb
# DB_USER=postgres
# DB_PASSWORD=replace_with_database_password
# DB_SSL=true

# JWT / auth
JWT_SECRET=replace_with_a_long_random_secret

# SMTP mail delivery
# Mailtrap example:
# SMTP_HOST=live.smtp.mailtrap.io
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=api
# SMTP_PASS=replace_with_your_mailtrap_password
# SMTP_FROM=Attendance System <noreply@example.com>
SMTP_HOST=live.smtp.mailtrap.io
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=api
SMTP_PASS=replace_with_your_mailtrap_password
SMTP_FROM=Attendance System <noreply@example.com>
